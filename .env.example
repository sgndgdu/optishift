# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Neon dashboard → Project → Connection string → Copy
DATABASE_URL=postgresql://user:password@ep-xyz.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Python Optimization Engine (Railway) ─────────────────────────────────────
# Railway → Service → Settings → Domain (Public Networking)
ENGINE_URL=https://optishift-engine.up.railway.app

# ─── JWT Authentication ────────────────────────────────────────────────────────
# Güçlü, rastgele bir string (örn: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ─── Uygulama URL'i (Google OAuth redirect'i ve şifre sıfırlama linkleri için) ─
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Google ile Giriş — Opsiyonel (admin/manager/supervisor login+register) ───
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# (Web application). Yetkili yönlendirme URI: {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Web Push (VAPID) — Opsiyonel ─────────────────────────────────────────────
# npx web-push generate-vapid-keys komutuyla üret
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@optishift.app

# ─── Anthropic AI (AI açıklama özelliği için) — Opsiyonel ────────────────────
ANTHROPIC_API_KEY=

# ─── Stripe (Faturalandırma) — Opsiyonel ──────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
